@page "{id:int}"
@model ExpenseTracker.Pages.Expenses.DeleteModel

@{
    ViewData["Title"] = "Delete Expense";
}

<h1>Delete Expense</h1>

<h4>Are you sure you want to delete this expense?</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Date
    </dt>

    <dd class="col-sm-9">
        @Model.Expense.Date.ToShortDateString()
    </dd>

    <dt class="col-sm-3">
        Category
    </dt>

    <dd class="col-sm-9">
        @Model.Expense.Category
    </dd>

    <dt class="col-sm-3">
        Description
    </dt>

    <dd class="col-sm-9">
        @Model.Expense.Description
    </dd>

    <dt class="col-sm-3">
        Amount
    </dt>

    <dd class="col-sm-9">
        @Model.Expense.Amount
    </dd>

</dl>

<form method="post">

    <input type="hidden" asp-for="Expense.Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-page="./Index" class="btn btn-secondary">
        Cancel
    </a>

</form>